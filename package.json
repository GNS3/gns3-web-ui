{
  "name": "gns3-web-ui",
  "version": "3.1.0-dev.1",
  "author": {
    "name": "GNS3 Technology Inc.",
    "email": "developers@gns3.com"
  },
  "description": "Graphical Network Simulator-3 is a network software emulator.",
  "license": "GPLv3",
  "main": "main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/GNS3/gns3-web-ui.git"
  },
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "buildforproduction": "ng build --source-map=false --build-optimizer --configuration=production --base-href /static/web-ui/",
    "buildforgithub": "ng build --configuration=githubProd",
    "test": "ng test",
    "lint": "ng lint",
    "e2e": "ng e2e",
    "release": "build",
    "coverage": "ng test --watch=false --code-coverage",
    "prettier:base": "prettier",
    "prettier:check": "yarn prettier:base -- --list-different \"src/**/*.{ts,js,html,scss}\"",
    "prettier:write": "yarn prettier:base -- --write \"src/**/*.{ts,js,html,scss}\"",
    "generate-licenses-file": "yarn license-checker --production --csv --out licenses.csv",
    "postinstall": "node scripts/ensure-babel-runtime-link.js",
    "snyk-protect": "snyk-protect",
    "prepare": "husky install",
    "electron": "cross-env NODE_ENV=development electron .",
    "electron:dev": "concurrently -k \"npm start\" \"wait-on http://localhost:4200 && npm run electron\"",
    "build:electron": "ng build --configuration=electronProd --base-href ./",
    "electron:build": "npm run build:electron && electron-builder -w",
    "electron:build:all": "npm run build:electron && electron-builder -wml"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.0.0",
    "@angular/cdk": "^21.0.0",
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/material": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "@angular/platform-browser-dynamic": "^21.0.0",
    "@angular/router": "^21.0.0",
    "@snyk/protect": "^1.972.0",
    "@types/jest": "^27.0.2",
    "@types/mocha": "^9.1.1",
    "@types/react": "^17.0.34",
    "@types/react-dom": "^17.0.11",
    "angular-draggable-droppable": "^6.1.0",
    "angular-resizable-element": "^3.4.0",
    "bootstrap": "^5.1.3",
    "command-exists": "^1.2.9",
    "core-js": "^3.22.3",
    "css-tree": "^2.1.0",
    "eev": "^0.1.5",
    "github-markdown-css": "^5.9.0",
    "ini": "^3.0.0",
    "ipaddr.js": "^2.1.0",
    "marked": "^4.0.14",
    "material-design-icons": "^3.0.1",
    "mousetrap": "^1.6.5",
    "ng-circle-progress": "^1.6.0",
    "ng2-file-upload": "^3.0.0",
    "ngx-device-detector": "4.0.1",
    "ngx-json-viewer": "^3.2.1",
    "ngx-markdown": "^15.1.2",
    "node-fetch": "^3.2.10",
    "notosans-fontface": "^1.3.0",
    "postcss-loader": "^6.2.1",
    "prettier-plugin-organize-imports": "^2.3.4",
    "rxjs": "^7.5.0",
    "save-svg-as-png": "^1.4.17",
    "spark-md5": "^3.0.2",
    "spice-html5-bower": "^1.7.3",
    "svg-crowbar": "^0.7.0",
    "tree-kill": "^1.2.2",
    "tslib": "^2.4.0",
    "typeface-roboto": "^1.1.13",
    "xterm": "^4.18.0",
    "xterm-addon-attach": "^0.6.0",
    "xterm-addon-fit": "^0.5.0",
    "yargs": "^17.4.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.0.0",
    "@angular/cli": "^21.0.0",
    "@angular/compiler-cli": "^21.0.0",
    "@angular/language-service": "^21.0.0",
    "@babel/runtime": "^7.29.2",
    "@sentry/cli": "^2.0.4",
    "@tailwindcss/typography": "^0.5.19",
    "@types/jasmine": "^4.0.3",
    "@types/jasminewd2": "^2.0.10",
    "@types/node": "^17.0.31",
    "autoprefixer": "^10.4.27",
    "codelyzer": "^0.0.28",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^22.3.27",
    "electron-builder": "^24.6.4",
    "file-loader": "^6.2.0",
    "husky": "^8.0.3",
    "jasmine-core": "^4.1.0",
    "jasmine-spec-reporter": "^7.0.0",
    "jquery": "^3.6.0",
    "karma": "^6.3.19",
    "karma-chrome-launcher": "^3.1.1",
    "karma-cli": "^2.0.0",
    "karma-coverage-istanbul-reporter": "^3.0.3",
    "karma-jasmine": "^5.0.0",
    "karma-jasmine-html-reporter": "^1.7.0",
    "license-checker": "^25.0.1",
    "popper.js": "^1.16.1",
    "postcss": "^8.5.8",
    "prettier": "^2.6.2",
    "protractor": "^7.0.0",
    "replace": "^1.2.1",
    "rxjs-tslint": "^0.1.8",
    "tailwindcss": "^3.4.19",
    "ts-mockito": "^2.6.1",
    "ts-node": "^10.7.0",
    "tslint": "^6.1.3",
    "tslint-config-prettier": "^1.18.0",
    "typescript": "~5.9.0",
    "wait-on": "^7.2.0",
    "webpack": "^5.72.0",
    "yarn-upgrade-all": "^0.7.1"
  },
  "greenkeeper": {
    "ignore": [
      "typescript"
    ]
  },
  "snyk": true,
  "engines": {
    "node": ">=18.0.0"
  },
  "overrides": {
    "dompurify": "3.3.3",
    "dagre-d3-es": "7.0.13"
  },
  "resolutions": {
    "dompurify": "3.3.3",
    "dagre-d3-es": "7.0.13"
  },
  "build": {
    "appId": "com.gns3.webui",
    "productName": "GNS3 Web UI",
    "directories": {
      "output": "dist-electron",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "preload.js",
      "package.json",
      "ipc-handlers/**/*",
      "utils/**/*",
      "services/**/*",
      "node_modules/@angular/compiler/**/*",
      "node_modules/@angular/core/**/*",
      "node_modules/@angular/common/**/*",
      "node_modules/@angular/platform-browser/**/*",
      "node_modules/@angular/platform-browser-dynamic/**/*"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.network"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "build/icon.png",
      "category": "Network"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
