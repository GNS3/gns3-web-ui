{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "../out-tsc/electron",
    "baseUrl": "./",
    "paths": {
      "@components/*": ["app/components/*"],
      "@services/*": ["app/services/*"],
      "@resolvers/*": ["app/resolvers/*"],
      "@filters/*": ["app/filters/*"],
      "@models/*": ["app/models/*"]
    },
    "types": [],
    // Override target to ES2015 for Electron (Chromium 108+)
    // This fixes JIT compiler issues in Electron while not affecting Web UI
    "target": "es2015"
  },
  "files": [
    "main.electron.ts",
    "polyfills.ts"
  ],
  "include": [
    // "../src/**/*"
  ],
  "exclude": [
    "main.ts"
  ]
}
